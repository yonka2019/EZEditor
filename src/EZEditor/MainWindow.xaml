<Window x:Class="EZEditor.MainWindow"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="clr-namespace:EZEditor.ViewModels"
    xmlns:val="clr-namespace:EZEditor.Validation"
    Title="EZEditor" Width="760" Height="560"
    Icon="pack://application:,,,/EZEditor;component/icon.ico"
    FontFamily="{StaticResource UiFont}"
    Background="{StaticResource WindowBg}"
    TextOptions.TextFormattingMode="Ideal">

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveCommand}" />
        <KeyBinding Key="S" Modifiers="Ctrl+Shift" Command="{Binding SaveAsCommand}" />
        <KeyBinding Key="O" Modifiers="Ctrl" Command="{Binding OpenCommand}" />
        <KeyBinding Key="R" Modifiers="Ctrl" Command="{Binding ReloadCommand}" />
    </Window.InputBindings>

    <Window.Resources>
        <HierarchicalDataTemplate DataType="{x:Type vm:JsonNodeViewModel}" ItemsSource="{Binding Children}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Add child"
                                  Command="{Binding DataContext.AddChildCommand, Source={x:Reference Root}}"
                                  CommandParameter="{Binding}"/>
                        <MenuItem Header="Delete"
                                  Command="{Binding DataContext.DeleteNodeCommand, Source={x:Reference Root}}"
                                  CommandParameter="{Binding}"/>
                        <Separator/>
                        <MenuItem Header="Change type">
                            <MenuItem Header="String"  Command="{Binding DataContext.MakeStringCommand,  Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                            <MenuItem Header="Number"  Command="{Binding DataContext.MakeNumberCommand,  Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                            <MenuItem Header="Boolean" Command="{Binding DataContext.MakeBooleanCommand, Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                            <MenuItem Header="Null"    Command="{Binding DataContext.MakeNullCommand,    Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                            <MenuItem Header="Object"  Command="{Binding DataContext.MakeObjectCommand,  Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                            <MenuItem Header="Array"   Command="{Binding DataContext.MakeArrayCommand,   Source={x:Reference Root}}" CommandParameter="{Binding}"/>
                        </MenuItem>
                        <Separator/>
                        <MenuItem Header="Expand all"
                                  Command="{Binding DataContext.ExpandAllCommand, Source={x:Reference Root}}"/>
                        <MenuItem Header="Collapse all"
                                  Command="{Binding DataContext.CollapseAllCommand, Source={x:Reference Root}}"/>
                    </ContextMenu>
                </StackPanel.ContextMenu>

                <!-- Key: editable for object members; index/root label otherwise.
                     Hovering the key (not the value) reveals the field's type. -->
                <TextBox Style="{StaticResource KeyEditor}"
                         Text="{Binding Name, UpdateSourceTrigger=LostFocus}"
                         ToolTip="{Binding Kind}" ToolTipService.InitialShowDelay="400"
                         Visibility="{Binding IsObjectMember, Converter={StaticResource BoolToVis}}"/>
                <TextBlock Style="{StaticResource IndexLabel}" Text="{Binding DisplayName}"
                           ToolTip="{Binding Kind}" ToolTipService.InitialShowDelay="400"
                           Visibility="{Binding IsObjectMember, Converter={StaticResource InverseBoolToVis}}"/>

                <TextBlock Text=":" Foreground="{StaticResource TextMuted}" FontFamily="{StaticResource MonoFont}"
                           Margin="3,0,4,0" VerticalAlignment="Center"/>

                <!-- String -->
                <TextBox Style="{StaticResource ValueEditor}" Foreground="{StaticResource StringColor}"
                         Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}"
                         Visibility="{Binding Kind, Converter={StaticResource KindToVis}, ConverterParameter=String}"/>
                <!-- Number (red border + tooltip when the text is not a valid number) -->
                <TextBox Style="{StaticResource NumberEditor}"
                         Visibility="{Binding Kind, Converter={StaticResource KindToVis}, ConverterParameter=Number}">
                    <TextBox.Text>
                        <Binding Path="Value" UpdateSourceTrigger="PropertyChanged">
                            <Binding.ValidationRules>
                                <!-- Validate only what the user types (target->source), not values
                                     pushed from the model on load/type-change. -->
                                <val:NumberValidationRule ValidatesOnTargetUpdated="False" />
                            </Binding.ValidationRules>
                        </Binding>
                    </TextBox.Text>
                </TextBox>
                <!-- Boolean -->
                <ToggleButton Style="{StaticResource BoolSwitch}"
                              IsChecked="{Binding Value, Converter={StaticResource StrBool}, Mode=TwoWay}"
                              Visibility="{Binding Kind, Converter={StaticResource KindToVis}, ConverterParameter=Boolean}"/>
                <!-- Null -->
                <TextBlock Text="null" FontFamily="{StaticResource MonoFont}" FontStyle="Italic" FontSize="13"
                           Foreground="{StaticResource NullColor}" VerticalAlignment="Center" Margin="6,0,0,0"
                           Visibility="{Binding Kind, Converter={StaticResource KindToVis}, ConverterParameter=Null}"/>
                <!-- Object / Array child count -->
                <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="12.5" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center" Margin="2,0,0,0"
                           Text="{Binding Children.Count, StringFormat='{}{0} fields'}"
                           Visibility="{Binding Kind, Converter={StaticResource KindToVis}, ConverterParameter=Object}"/>
                <TextBlock FontFamily="{StaticResource MonoFont}" FontSize="12.5" Foreground="{StaticResource TextMuted}"
                           VerticalAlignment="Center" Margin="2,0,0,0"
                           Text="{Binding Children.Count, StringFormat='{}{0} items'}"
                           Visibility="{Binding Kind, Converter={StaticResource KindToVis}, ConverterParameter=Array}"/>
            </StackPanel>
        </HierarchicalDataTemplate>

        <DataTemplate DataType="{x:Type vm:JsonDocument}">
            <Border Margin="14" CornerRadius="10" Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Hairline}" BorderThickness="1">
                <TreeView x:Name="Tree" ItemsSource="{Binding Roots}"
                          ItemContainerStyle="{StaticResource JsonTreeItem}"
                          Padding="10,8" Margin="2"
                          Tag="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"
                          PreviewMouseWheel="OnTreePreviewMouseWheel"
                          ScrollViewer.CanContentScroll="True"
                          VirtualizingPanel.IsVirtualizing="True"
                          VirtualizingPanel.VirtualizationMode="Recycling"
                          VirtualizingPanel.ScrollUnit="Item">
                    <TreeView.Resources>
                        <SolidColorBrush x:Key="{x:Static SystemColors.ControlBrushKey}" Color="#161922"/>
                    </TreeView.Resources>
                    <TreeView.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Expand all"
                                      Command="{Binding PlacementTarget.Tag.ExpandAllCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                            <MenuItem Header="Collapse all"
                                      Command="{Binding PlacementTarget.Tag.CollapseAllCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"/>
                        </ContextMenu>
                    </TreeView.ContextMenu>
                </TreeView>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:CsvDocument}">
            <Border Margin="14" CornerRadius="10" Background="{StaticResource Surface}"
                    BorderBrush="{StaticResource Hairline}" BorderThickness="1">
                <DataGrid x:Name="CsvGrid" ItemsSource="{Binding Rows}"
                          Loaded="OnCsvGridLoaded"
                          Tag="{Binding}"
                          Margin="2" Padding="6">
                    <DataGrid.ContextMenu>
                        <ContextMenu Tag="{Binding}">
                            <MenuItem Header="Add row" Click="OnCsvAddRow" />
                            <MenuItem Header="Delete selected row" Click="OnCsvDeleteRow" />
                            <Separator/>
                            <MenuItem Header="Add column" Click="OnCsvAddColumn" />
                        </ContextMenu>
                    </DataGrid.ContextMenu>
                </DataGrid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <!-- Toolbar -->
        <Border DockPanel.Dock="Top" Background="{StaticResource Toolbar}"
                BorderBrush="{StaticResource Hairline}" BorderThickness="0,0,0,1" Padding="14,10">
            <DockPanel>
                <TextBox DockPanel.Dock="Right" Style="{StaticResource SearchBox}" Width="140" Height="26" Margin="8,0,0,0"
                         Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"/>
                <StackPanel Orientation="Horizontal">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,20,0" FontSize="20">
                        <Run Text="EZ" FontWeight="SemiBold" Foreground="#82AAFF"/><Run Text="Editor" Foreground="#E6E9F2"/>
                    </TextBlock>
                    <Button Style="{StaticResource ToolbarButton}" Content="Open" Command="{Binding OpenCommand}"/>
                    <Button Style="{StaticResource ToolbarButton}" Content="Save" Command="{Binding SaveCommand}"/>
                    <Button Style="{StaticResource ToolbarButton}" Content="Save As" Command="{Binding SaveAsCommand}"/>
                    <Button Style="{StaticResource ToolbarButton}" Content="Reload" Command="{Binding ReloadCommand}"
                            ToolTip="Reload from disk (Ctrl+R)"/>
                    <Border Width="1" Margin="6,5,12,5" Background="{StaticResource Hairline}"/>
                    <Button Style="{StaticResource ToolbarButton}" Content="Open Externally" Click="OnOpenExternally"
                            ToolTip="Open the current file in Notepad++ (if installed), otherwise the default app"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{StaticResource Toolbar}"
                BorderBrush="{StaticResource Hairline}" BorderThickness="0,1,0,0" Padding="16,7">
            <DockPanel>
                <TextBlock DockPanel.Dock="Right" Text="by yonka" Foreground="{StaticResource TextMuted}"
                           FontFamily="{StaticResource MonoFont}" FontSize="12" Opacity="0.85"/>
                <TextBlock Text="{Binding StatusText}" Foreground="{StaticResource TextMuted}"
                           FontFamily="{StaticResource MonoFont}" FontSize="12"/>
            </DockPanel>
        </Border>

        <!-- Document editor — template selected by CurrentDocument type -->
        <ContentControl Content="{Binding CurrentDocument}" />
    </DockPanel>
</Window>
