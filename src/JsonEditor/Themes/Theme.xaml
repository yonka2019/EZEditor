<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:JsonEditor.Converters">

    <!-- ============================= Converters ============================= -->
    <conv:KindToVisibilityConverter x:Key="KindToVis" />
    <conv:StringBoolConverter x:Key="StrBool" />
    <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />

    <!-- ============================== Palette =============================== -->
    <SolidColorBrush x:Key="WindowBg"     Color="#0F1116" />
    <SolidColorBrush x:Key="Surface"      Color="#161922" />
    <SolidColorBrush x:Key="Toolbar"      Color="#0C0E13" />
    <SolidColorBrush x:Key="Hairline"     Color="#262B38" />
    <SolidColorBrush x:Key="RowHover"     Color="#1B2130" />
    <SolidColorBrush x:Key="RowSelected"  Color="#233152" />
    <SolidColorBrush x:Key="TextPrimary"  Color="#E6E9F2" />
    <SolidColorBrush x:Key="TextMuted"    Color="#79839B" />
    <SolidColorBrush x:Key="Accent"       Color="#5B8CFF" />
    <SolidColorBrush x:Key="KeyColor"     Color="#82AAFF" />
    <SolidColorBrush x:Key="StringColor"  Color="#A6D177" />
    <SolidColorBrush x:Key="NumberColor"  Color="#F0A35E" />
    <SolidColorBrush x:Key="BoolColor"    Color="#C99BF0" />
    <SolidColorBrush x:Key="NullColor"    Color="#66708A" />
    <SolidColorBrush x:Key="EditorHover"  Color="#1A1E29" />

    <FontFamily x:Key="MonoFont">Cascadia Code, Consolas</FontFamily>
    <FontFamily x:Key="UiFont">Segoe UI</FontFamily>

    <!-- ========================= Inline text editor ======================== -->
    <Style x:Key="InlineEditor" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderBrush" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="Padding" Value="6,2" />
        <Setter Property="MinWidth" Value="44" />
        <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
        <Setter Property="SelectionBrush" Value="{StaticResource Accent}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="4">
                        <ScrollViewer x:Name="PART_ContentHost" Focusable="False"
                                      VerticalScrollBarVisibility="Hidden"
                                      HorizontalScrollBarVisibility="Hidden" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource EditorHover}" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource WindowBg}" />
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="KeyEditor" TargetType="TextBox" BasedOn="{StaticResource InlineEditor}">
        <Setter Property="Foreground" Value="{StaticResource KeyColor}" />
        <Setter Property="MinWidth" Value="60" />
    </Style>

    <Style x:Key="ValueEditor" TargetType="TextBox" BasedOn="{StaticResource InlineEditor}">
        <Setter Property="MinWidth" Value="80" />
    </Style>

    <!-- Number editor: shows a red border + tooltip when the value is not a valid number -->
    <Style x:Key="NumberEditor" TargetType="TextBox" BasedOn="{StaticResource ValueEditor}">
        <Setter Property="Foreground" Value="{StaticResource NumberColor}" />
        <Setter Property="Validation.ErrorTemplate">
            <Setter.Value>
                <ControlTemplate>
                    <Grid>
                        <Border BorderBrush="#FF6B6B" BorderThickness="1.4" CornerRadius="4" Margin="-2" />
                        <AdornedElementPlaceholder />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
        <Style.Triggers>
            <Trigger Property="Validation.HasError" Value="True">
                <Setter Property="Foreground" Value="#FF8A8A" />
                <Setter Property="ToolTip"
                        Value="{Binding (Validation.Errors)[0].ErrorContent, RelativeSource={RelativeSource Self}}" />
            </Trigger>
        </Style.Triggers>
    </Style>

    <!-- ============================ Index / label ========================== -->
    <Style x:Key="IndexLabel" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource TextMuted}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Margin" Value="6,0,0,0" />
    </Style>

    <!-- ============================ Toolbar button ========================= -->
    <Style x:Key="ToolbarButton" TargetType="Button">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Margin" Value="0,0,8,0" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="bd" Background="#1B212C" CornerRadius="6" Padding="14,7">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#262D3B" />
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="#151A23" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================== Search box =========================== -->
    <Style x:Key="SearchBox" TargetType="TextBox">
        <Setter Property="FontFamily" Value="{StaticResource UiFont}" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="CaretBrush" Value="{StaticResource Accent}" />
        <Setter Property="SelectionBrush" Value="{StaticResource Accent}" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Border x:Name="bd" Background="{StaticResource WindowBg}"
                            BorderBrush="{StaticResource Hairline}" BorderThickness="1" CornerRadius="6">
                        <Grid>
                            <TextBlock x:Name="ph" Text="Filter…" Foreground="{StaticResource TextMuted}"
                                       Margin="10,0" VerticalAlignment="Center" IsHitTestVisible="False"
                                       Visibility="Collapsed" />
                            <ScrollViewer x:Name="PART_ContentHost" Margin="10,0" Focusable="False"
                                          VerticalScrollBarVisibility="Hidden" HorizontalScrollBarVisibility="Hidden" />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Text" Value="">
                            <Setter TargetName="ph" Property="Visibility" Value="Visible" />
                        </Trigger>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Accent}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========================= Boolean toggle switch ===================== -->
    <Style x:Key="BoolSwitch" TargetType="ToggleButton">
        <Setter Property="Width" Value="36" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border x:Name="track" CornerRadius="9" Background="{StaticResource Hairline}">
                        <Ellipse x:Name="thumb" Width="14" Height="14" Fill="{StaticResource TextPrimary}"
                                 HorizontalAlignment="Left" Margin="2,0,0,0" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="track" Property="Background" Value="{StaticResource BoolColor}" />
                            <Setter TargetName="thumb" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="thumb" Property="Margin" Value="0,0,2,0" />
                            <Setter TargetName="thumb" Property="Fill" Value="#1A1430" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================ Tree chevron =========================== -->
    <Style x:Key="TreeChevron" TargetType="ToggleButton">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Width" Value="18" />
        <Setter Property="Height" Value="18" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ToggleButton">
                    <Border Background="Transparent">
                        <Path x:Name="arrow" Data="M 5 3 L 10 8 L 5 13"
                              Stroke="{StaticResource TextMuted}" StrokeThickness="1.6"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"
                              HorizontalAlignment="Center" VerticalAlignment="Center"
                              RenderTransformOrigin="0.5,0.5" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="arrow" Property="RenderTransform">
                                <Setter.Value>
                                    <RotateTransform Angle="90" />
                                </Setter.Value>
                            </Setter>
                        </Trigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="arrow" Property="Stroke" Value="{StaticResource TextPrimary}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ============================== TreeView ============================= -->
    <Style TargetType="TreeView">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
    </Style>

    <!-- =========================== TreeViewItem =========================== -->
    <Style x:Key="JsonTreeItem" TargetType="TreeViewItem">
        <Setter Property="Foreground" Value="{StaticResource TextPrimary}" />
        <Setter Property="FocusVisualStyle" Value="{x:Null}" />
        <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}" />
        <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}" />
        <Setter Property="Visibility" Value="{Binding IsFilteredOut, Converter={StaticResource InverseBoolToVis}}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TreeViewItem">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- full-width row highlight (header row only, so child hover never bleeds up) -->
                        <Border x:Name="rowBg" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                                CornerRadius="5" Margin="0,1">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="Transparent" />
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="{StaticResource RowHover}" />
                                        </Trigger>
                                        <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=TreeViewItem}}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource RowSelected}" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                        </Border>

                        <ToggleButton x:Name="Expander" Grid.Row="0" Grid.Column="0"
                                      Style="{StaticResource TreeChevron}"
                                      VerticalAlignment="Center"
                                      IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}" />

                        <Border Grid.Row="0" Grid.Column="1" Padding="2,3" Background="Transparent">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Left" VerticalAlignment="Center" />
                        </Border>

                        <Border x:Name="childHost" Grid.Row="1" Grid.Column="1" Margin="8,0,0,0"
                                BorderBrush="{StaticResource Hairline}" BorderThickness="1,0,0,0">
                            <ItemsPresenter />
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsExpanded" Value="False">
                            <Setter TargetName="childHost" Property="Visibility" Value="Collapsed" />
                        </Trigger>
                        <Trigger Property="HasItems" Value="False">
                            <Setter TargetName="Expander" Property="Visibility" Value="Hidden" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
